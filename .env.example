API_EIMZO_URL=http://127.0.0.1:64646
# Optional: prefix added before /{plugin}/{name}, for example /didox
# API_EIMZO_PATH_PREFIX=/didox
# Deprecated: x_account_name is no longer used by E-IMZO API after JWT login rollout.
# API_EIMZO_SEND_ACCOUNT_HEADER=false
WS_SERVER_HOST=127.0.0.1
WS_SERVER_PORT=64443
# Set this to /service/cryptapi if the site connects to that legacy path.
WS_SERVER_PATH=/
LOG_LEVEL=INFO
# Optional: auto-start the app for the current Windows user after sign-in.
# Set to false to remove the app from the current-user Run registry key.
# WINDOWS_AUTO_START=true
# Optional: self-update from GitHub Releases (only works for packaged .exe).
# AUTO_UPDATE_ENABLED=true
# Optional: release asset name to download.
# AUTO_UPDATE_ASSET_NAME=eimzo-atb-client.exe
# Optional: timeout for release check/download requests.
# AUTO_UPDATE_CHECK_TIMEOUT_SECONDS=5
# Optional: check interval in seconds after startup. Default is 900 (15 minutes).
# AUTO_UPDATE_CHECK_INTERVAL_SECONDS=900
# Optional: directory for detailed rotating logs.
# By default logs are written to %LOCALAPPDATA%\E-IMZO-ATB-Client\logs
# APP_LOG_DIR=C:\Users\<User>\AppData\Local\E-IMZO-ATB-Client\logs
# Optional: custom icon for tray and EXE build.
# If omitted, the build script also auto-detects icon.ico in the project root
# APP_ICON_PATH=C:\path\to\app.ico
# Optional: use a CA-signed certificate for the local WSS server.
# WS_SERVER_CERT_PATH=C:\path\to\server-cert.pem
# WS_SERVER_KEY_PATH=C:\path\to\server-key.pem
# Optional: when managed certificates are used, import the generated root CA
# into the Windows current-user trust store so browsers trust wss://127.0.0.1.
# LOCAL_CERT_INSTALL_TO_WINDOWS_ROOT_STORE=true
# Optional: trust this CA certificate when API_EIMZO_URL uses HTTPS.
# API_EIMZO_CA_CERT_PATH=C:\path\to\ca-cert.pem
# Optional: force bundled certifi CA roots instead of Windows cert store.
# Useful when the current-user certificate store is corrupted.
# EIMZO_FORCE_CERTIFI_BUNDLE=true
# Optional: disable automatic fallback from Windows cert store to certifi.
# EIMZO_DISABLE_SSL_CERT_STORE_FALLBACK=true
